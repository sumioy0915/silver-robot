---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout title="お問い合わせ" page="/contact">

  <div class="bg-stone-800 text-white px-4 md:px-8 pt-5 pb-6">
    <h1 class="text-xl font-bold mb-1">
      <i class="ti ti-mail text-lg align-[-2px] mr-2"></i>お問い合わせ
    </h1>
    <p class="text-sm text-white/80">講座予約・ご相談はこちら</p>
  </div>

  <!-- クイック連絡先 -->
  <section class="px-4 md:px-8 py-5">
    <p class="text-[11px] text-stone-400 uppercase tracking-widest mb-3 font-medium">連絡先</p>
    <div class="bg-white border border-stone-200 rounded-2xl overflow-hidden mb-4">
      <a href={`tel:${SITE.phone.replace(/-/g,'')}`}
        class="flex items-center justify-between px-4 md:px-8 py-3.5 border-b border-stone-100 no-underline hover:bg-stone-50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-[#e8f4ee] flex items-center justify-center">
            <i class="ti ti-phone text-[#1a5c3a] text-base"></i>
          </div>
          <div>
            <p class="text-xs text-stone-400">電話</p>
            <p class="text-sm font-medium text-[#1a5c3a]">{SITE.phone}</p>
          </div>
        </div>
        <i class="ti ti-chevron-right text-stone-300"></i>
      </a>
      <div class="flex items-center justify-between px-4 md:px-8 py-3.5 border-b border-stone-100">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-[#e8f4ee] flex items-center justify-center">
            <i class="ti ti-mail text-[#1a5c3a] text-base"></i>
          </div>
          <div>
            <p class="text-xs text-stone-400">メール</p>
            <p class="text-sm font-medium text-stone-700">{SITE.email}</p>
          </div>
        </div>
      </div>
      <div class="flex items-center px-4 md:px-8 py-3.5">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-stone-100 flex items-center justify-center">
            <i class="ti ti-clock text-stone-500 text-base"></i>
          </div>
          <div>
            <p class="text-xs text-stone-400">受付時間</p>
            <p class="text-sm text-stone-700">{SITE.hours}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- LINE -->
    <a href={SITE.lineUrl} target="_blank" rel="noopener"
      class="flex items-center gap-3 bg-[#06C755] text-white px-4 md:px-8 py-3 rounded-xl no-underline mb-5">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
      <span class="text-sm font-medium">LINEで友だち追加する</span>
    </a>
  </section>

  <div class="h-px bg-stone-100 mx-4"></div>

  <!-- お問い合わせフォーム -->
  <section class="px-4 md:px-8 py-5">
    <p class="text-[11px] text-stone-400 uppercase tracking-widest mb-4 font-medium">メッセージを送る</p>
    <form id="contact-form" class="flex flex-col gap-4" novalidate>
      <div>
        <label class="block text-xs text-stone-500 mb-1.5">お名前 <span class="text-red-400">*</span></label>
        <input type="text" name="name" required placeholder="山田 花子"
          class="w-full text-sm px-3 py-2.5 border border-stone-300 rounded-xl bg-white text-stone-800 placeholder-stone-300 focus:outline-none focus:border-[#1a5c3a] transition-colors" />
      </div>
      <div>
        <label class="block text-xs text-stone-500 mb-1.5">メールアドレス <span class="text-red-400">*</span></label>
        <input type="email" name="email" required placeholder="example@email.com"
          class="w-full text-sm px-3 py-2.5 border border-stone-300 rounded-xl bg-white text-stone-800 placeholder-stone-300 focus:outline-none focus:border-[#1a5c3a] transition-colors" />
      </div>
      <div>
        <label class="block text-xs text-stone-500 mb-1.5">電話番号（任意）</label>
        <input type="tel" name="tel" placeholder="090-0000-0000"
          class="w-full text-sm px-3 py-2.5 border border-stone-300 rounded-xl bg-white text-stone-800 placeholder-stone-300 focus:outline-none focus:border-[#1a5c3a] transition-colors" />
      </div>
      <div>
        <label class="block text-xs text-stone-500 mb-1.5">お問い合わせ種別 <span class="text-red-400">*</span></label>
        <select name="category" required
          class="w-full text-sm px-3 py-2.5 border border-stone-300 rounded-xl bg-white text-stone-800 focus:outline-none focus:border-[#1a5c3a] transition-colors appearance-none">
          <option value="">選択してください</option>
          <option>講座・イベントの予約</option>
          <option>スマホ・PCの相談</option>
          <option>HP制作のご依頼</option>
          <option>KCNへの参加について</option>
          <option>その他</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-stone-500 mb-1.5">メッセージ <span class="text-red-400">*</span></label>
        <textarea name="message" required rows="4" placeholder="ご質問・ご要望をご記入ください"
          class="w-full text-sm px-3 py-2.5 border border-stone-300 rounded-xl bg-white text-stone-800 placeholder-stone-300 focus:outline-none focus:border-[#1a5c3a] transition-colors resize-none"></textarea>
      </div>
      <button type="submit"
        class="w-full bg-[#1a5c3a] text-white text-sm font-medium py-3.5 rounded-xl hover:bg-[#0F6E56] transition-colors">
        送信する
      </button>
      <div id="form-msg" class="hidden text-sm text-center py-2 rounded-xl"></div>
    </form>
  </section>

  <div class="h-px bg-stone-100 mx-4"></div>

  <!-- 所在地 -->
  <section class="px-4 md:px-8 py-5">
    <p class="text-[11px] text-stone-400 uppercase tracking-widest mb-3 font-medium">所在地</p>
    <div class="bg-white border border-stone-200 rounded-2xl p-4">
      <p class="text-sm font-medium text-stone-800 mb-1">長谷BASE（KCN事務局）</p>
      <p class="text-xs text-stone-500 leading-relaxed">{SITE.address}</p>
      <p class="text-xs text-stone-500 mt-1">{SITE.access}</p>
      <div class="mt-3 h-px bg-stone-100"></div>
      <p class="text-xs text-stone-400 mt-3">{SITE.hours}</p>
    </div>
    <!-- 地図プレースホルダー（実装時はLeaflet.jsに置換） -->
    <div class="mt-3 bg-stone-100 rounded-2xl h-36 flex flex-col items-center justify-center text-stone-400">
      <i class="ti ti-map text-3xl mb-1"></i>
      <p class="text-xs">地図（Leaflet.js / OpenStreetMap）</p>
    </div>
  </section>

</Layout>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const msg  = document.getElementById('form-msg') as HTMLDivElement;

form.addEventListener('submit', (e) => {
  e.preventDefault();
  msg.className = 'text-sm text-center py-2 rounded-xl bg-[#e8f4ee] text-[#0F6E56]';
  msg.textContent = 'ありがとうございます。内容を確認の上、ご連絡いたします。';
  form.reset();
  msg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>
