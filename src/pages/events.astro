---
import Layout from '../layouts/Layout.astro';
import { EVENTS, SITE } from '../data/site';
---

<Layout title="イベント" page="/events">

  <div class="bg-[#1a5c3a] text-white px-4 pt-5 pb-6">
    <h1 class="text-xl font-bold mb-1">
      <i class="ti ti-calendar text-lg align-[-2px] mr-2"></i>イベント・講座スケジュール
    </h1>
    <p class="text-sm text-white/80">2026年 開催予定一覧</p>
  </div>

  <!-- フィルタータグ -->
  <div class="px-4 py-3 bg-white border-b border-stone-100 overflow-x-auto">
    <div class="flex gap-2 min-w-max">
      <button class="filter-btn active text-xs px-3 py-1.5 rounded-full border border-[#1a5c3a] bg-[#1a5c3a] text-white transition-colors" data-filter="all">
        すべて
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-stone-300 text-stone-500 transition-colors" data-filter="シニア">
        シニア
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-stone-300 text-stone-500 transition-colors" data-filter="こども">
        こども
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-stone-300 text-stone-500 transition-colors" data-filter="スマホ">
        スマホ
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-stone-300 text-stone-500 transition-colors" data-filter="プログラミング">
        プログラミング
      </button>
    </div>
  </div>

  <section class="px-4 py-4">
    <p class="text-[11px] text-stone-400 uppercase tracking-widest mb-3 font-medium">7月の予定</p>
    <div class="flex flex-col gap-3" id="event-list">
      {EVENTS.map(ev => (
        <div
          class="event-card flex gap-3 items-start bg-white border border-stone-200 rounded-xl p-3.5"
          data-tags={ev.tags.join(',')}
        >
          <div class="bg-[#e8f4ee] rounded-lg px-3 py-2 text-center flex-shrink-0 min-w-[46px]">
            <div class="text-[10px] text-[#0F6E56] font-medium">{ev.month}</div>
            <div class="text-2xl font-bold text-[#1a5c3a] leading-none">{ev.day}</div>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-stone-800">{ev.title}</p>
            <p class="text-xs text-stone-500 mt-1">
              <i class="ti ti-clock text-xs align-[-1px] mr-1"></i>{ev.time}
            </p>
            <p class="text-xs text-stone-500 mt-0.5">
              <i class="ti ti-map-pin text-xs align-[-1px] mr-1"></i>{ev.venue}
            </p>
            <p class="text-xs text-stone-500 mt-0.5">
              <i class="ti ti-coin text-xs align-[-1px] mr-1"></i>{ev.fee}
            </p>
            {ev.note && (
              <p class="text-xs text-amber-600 mt-1 bg-amber-50 px-2 py-1 rounded-lg">{ev.note}</p>
            )}
            <div class="flex gap-1.5 mt-2 flex-wrap">
              {ev.tags.map(tag => (
                <span class="text-[10px] bg-[#e8f4ee] text-[#0F6E56] px-2 py-0.5 rounded-full">{tag}</span>
              ))}
              {ev.reservation && (
                <span class="text-[10px] bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full">要予約</span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 予約案内 -->
  <div class="mx-4 mb-6 bg-[#e8f4ee] rounded-2xl p-4">
    <p class="text-sm font-medium text-[#1a5c3a] mb-2">
      <i class="ti ti-phone text-base align-[-2px] mr-1"></i>ご予約・お問い合わせ
    </p>
    <p class="text-xs text-[#0F6E56] leading-relaxed">
      講座・相談のご予約は電話またはメールで随時受け付けています。<br>
      お気軽にご連絡ください。
    </p>
    <div class="mt-3 flex flex-col gap-2">
      <a href={`tel:${SITE.phone.replace(/-/g,'')}`}
        class="flex items-center gap-2 bg-[#1a5c3a] text-white text-sm font-medium px-4 py-2.5 rounded-xl no-underline">
        <i class="ti ti-phone text-base"></i>
        {SITE.phone} に電話する
      </a>
      <a href="/contact"
        class="flex items-center gap-2 bg-white border border-[#1a5c3a] text-[#1a5c3a] text-sm font-medium px-4 py-2.5 rounded-xl no-underline">
        <i class="ti ti-mail text-base"></i>
        メールで問い合わせる
      </a>
    </div>
  </div>

</Layout>

<script>
const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards = document.querySelectorAll<HTMLElement>('.event-card');

buttons.forEach(btn => {
  btn.addEventListener('click', () => {
    const filter = btn.dataset.filter ?? 'all';
    buttons.forEach(b => {
      b.classList.remove('active', 'bg-[#1a5c3a]', 'text-white', 'border-[#1a5c3a]');
      b.classList.add('border-stone-300', 'text-stone-500');
    });
    btn.classList.add('active', 'bg-[#1a5c3a]', 'text-white', 'border-[#1a5c3a]');
    btn.classList.remove('border-stone-300', 'text-stone-500');

    cards.forEach(card => {
      const tags = card.dataset.tags ?? '';
      if (filter === 'all' || tags.includes(filter)) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  });
});
</script>
