---
import { SITE, NAV } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  page?: string;
}

const { title = SITE.name, description = SITE.tagline, page = '' } = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === SITE.name ? title : `${title} | ${SITE.name}`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css" />
</head>
<body class="bg-stone-50 text-stone-900 font-sans">

  <!-- mobile frame -->
  <div class="min-h-screen max-w-md mx-auto flex flex-col bg-white shadow-sm relative">

    <!-- top header (desktop hint) -->
    <header class="bg-[#1a5c3a] text-white px-4 py-3 flex items-center justify-between sticky top-0 z-30">
      <a href="/" class="flex items-center gap-2 no-underline text-white">
        <span class="text-lg font-bold tracking-tight">KCN</span>
        <span class="text-xs opacity-75 hidden sm:inline">鎌倉市民ネット</span>
      </a>
      <a href={`tel:${SITE.phone.replace(/-/g,'')}`} class="text-xs opacity-90 flex items-center gap-1">
        <i class="ti ti-phone text-sm"></i>
        {SITE.phone}
      </a>
    </header>

    <!-- main content slot -->
    <main class="flex-1 pb-20">
      <slot />
    </main>

    <!-- bottom navigation -->
    <nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-md bg-white border-t border-stone-200 z-40">
      <ul class="flex justify-around items-center py-2 px-1">
        {NAV.map(item => {
          const isActive = page === item.href || (item.href !== '/' && page.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class={`flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs transition-colors
                  ${isActive ? 'text-[#1a5c3a] font-medium' : 'text-stone-400 hover:text-stone-600'}`}
              >
                <i class={`ti ti-${item.icon} text-xl`}></i>
                <span class="text-[10px]">{item.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>

</body>
</html>
